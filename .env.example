# Path to the SQLite database file.
# Default used by start.sh when a Railway volume is mounted at /data.
DB_PATH=/data/github_research_v1.db

# Direct-download URL for the database file.
# start.sh downloads it automatically on first boot if DB_PATH doesn't exist.
# Set this to an S3 pre-signed URL, Cloudflare R2 public URL, etc.
# DB_URL=https://your-bucket.s3.amazonaws.com/github_research_v1.db

# Port the uvicorn server listens on (Railway injects PORT automatically).
PORT=8000
